#!/usr/bin/env sh

# Resolve a workspace-aware Rails port (same as bin/dev).
. bin/orchestrator/env
PORT="$(bin/orchestrator/dev-port)"
export PORT

export INERTIA_SSR=1

if workspace_detection_present; then
  VITE_PORT=$((PORT + 1))
  export VITE_PORT
fi

# Build the SSR bundle once before starting the process group, so the
# Node SSR server has something to load on first start. The watcher in
# Procfile.ssr keeps it fresh after that.
echo "Building SSR bundle..."
npx vite build --ssr || exit 1

if ! command -v overmind 1> /dev/null 2>&1
then
  if gem list --no-installed --exact --silent foreman; then
    echo "Installing foreman..."
    gem install foreman
  fi

  exec foreman start -f Procfile.ssr "$@"
fi

exec overmind start -f Procfile.ssr "$@"
